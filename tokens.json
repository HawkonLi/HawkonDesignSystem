{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Hawkon Personal Design System — design tokens (W3C format). Primary: Airforce Blue. Accent: Sky Blue.",
  "color": {
    "airforce": {
      "50":  { "$type": "color", "$value": "#EAF1F6" },
      "100": { "$type": "color", "$value": "#C9DCE8" },
      "200": { "$type": "color", "$value": "#9FBFD3" },
      "300": { "$type": "color", "$value": "#6E9BB8" },
      "400": { "$type": "color", "$value": "#41759A" },
      "500": { "$type": "color", "$value": "#1B4965" },
      "600": { "$type": "color", "$value": "#163C54" },
      "700": { "$type": "color", "$value": "#112F43" },
      "800": { "$type": "color", "$value": "#0C2232" },
      "900": { "$type": "color", "$value": "#071521" }
    },
    "sky": {
      "50":  { "$type": "color", "$value": "#EEF7FC" },
      "100": { "$type": "color", "$value": "#D2EAF6" },
      "200": { "$type": "color", "$value": "#A9D6EC" },
      "300": { "$type": "color", "$value": "#7FC1E2" },
      "400": { "$type": "color", "$value": "#5FA8D3" },
      "500": { "$type": "color", "$value": "#3D8FC4" },
      "600": { "$type": "color", "$value": "#2E73A3" },
      "700": { "$type": "color", "$value": "#245A80" },
      "800": { "$type": "color", "$value": "#1A4260" },
      "900": { "$type": "color", "$value": "#102B40" }
    },
    "neutral": {
      "0":    { "$type": "color", "$value": "#FFFFFF" },
      "50":   { "$type": "color", "$value": "#F6F8FA" },
      "100":  { "$type": "color", "$value": "#ECEFF3" },
      "200":  { "$type": "color", "$value": "#DCE3EA" },
      "300":  { "$type": "color", "$value": "#C2CCD6" },
      "400":  { "$type": "color", "$value": "#97A3B0" },
      "500":  { "$type": "color", "$value": "#6B7886" },
      "600":  { "$type": "color", "$value": "#4E5A67" },
      "700":  { "$type": "color", "$value": "#38424D" },
      "800":  { "$type": "color", "$value": "#232B33" },
      "900":  { "$type": "color", "$value": "#141A20" },
      "1000": { "$type": "color", "$value": "#0A0E12" }
    },
    "success": { "50": { "$type": "color", "$value": "#E8F5EE" }, "300": { "$type": "color", "$value": "#79C9A2" }, "500": { "$type": "color", "$value": "#2E9E6B" }, "700": { "$type": "color", "$value": "#1E6B48" } },
    "warning": { "50": { "$type": "color", "$value": "#FCF3DF" }, "300": { "$type": "color", "$value": "#F0CB66" }, "500": { "$type": "color", "$value": "#E0A100" }, "700": { "$type": "color", "$value": "#9A6F00" } },
    "error":   { "50": { "$type": "color", "$value": "#FBEAEA" }, "300": { "$type": "color", "$value": "#E88B8B" }, "500": { "$type": "color", "$value": "#D64545" }, "700": { "$type": "color", "$value": "#932929" } },
    "ember":   { "50": { "$type": "color", "$value": "#FBEFE6" }, "300": { "$type": "color", "$value": "#EFB084" }, "500": { "$type": "color", "$value": "#E07A3F" }, "700": { "$type": "color", "$value": "#A8501F" } }
  },
  "semantic": {
    "light": {
      "bg-canvas":         { "$type": "color", "$value": "{color.neutral.50}" },
      "bg-surface":        { "$type": "color", "$value": "{color.neutral.0}" },
      "bg-surface-raised": { "$type": "color", "$value": "{color.neutral.0}" },
      "bg-subtle":         { "$type": "color", "$value": "{color.neutral.100}" },
      "bg-inverse":        { "$type": "color", "$value": "{color.neutral.900}" },
      "text-primary":      { "$type": "color", "$value": "{color.neutral.900}" },
      "text-secondary":    { "$type": "color", "$value": "{color.neutral.600}" },
      "text-tertiary":     { "$type": "color", "$value": "{color.neutral.500}" },
      "text-on-accent":    { "$type": "color", "$value": "{color.neutral.0}" },
      "border-default":    { "$type": "color", "$value": "{color.neutral.200}" },
      "border-strong":     { "$type": "color", "$value": "{color.neutral.300}" },
      "accent-primary":       { "$type": "color", "$value": "{color.airforce.500}" },
      "accent-primary-hover": { "$type": "color", "$value": "{color.airforce.600}" },
      "accent-secondary":     { "$type": "color", "$value": "{color.sky.500}" },
      "accent-subtle-bg":     { "$type": "color", "$value": "{color.airforce.50}" },
      "accent-ember":         { "$type": "color", "$value": "{color.ember.500}" },
      "focus-ring":           { "$type": "color", "$value": "{color.sky.400}" },
      "status-success":   { "$type": "color", "$value": "{color.success.500}" },
      "status-warning":   { "$type": "color", "$value": "{color.warning.500}" },
      "status-error":     { "$type": "color", "$value": "{color.error.500}" },
      "status-info":      { "$type": "color", "$value": "{color.sky.500}" }
    },
    "dark": {
      "bg-canvas":         { "$type": "color", "$value": "{color.neutral.1000}" },
      "bg-surface":        { "$type": "color", "$value": "{color.neutral.900}" },
      "bg-surface-raised": { "$type": "color", "$value": "{color.neutral.800}" },
      "bg-subtle":         { "$type": "color", "$value": "{color.neutral.800}" },
      "bg-inverse":        { "$type": "color", "$value": "{color.neutral.0}" },
      "text-primary":      { "$type": "color", "$value": "{color.neutral.100}" },
      "text-secondary":    { "$type": "color", "$value": "{color.neutral.300}" },
      "text-tertiary":     { "$type": "color", "$value": "{color.neutral.400}" },
      "text-on-accent":    { "$type": "color", "$value": "{color.airforce.900}" },
      "border-default":    { "$type": "color", "$value": "{color.neutral.700}" },
      "border-strong":     { "$type": "color", "$value": "{color.neutral.600}" },
      "accent-primary":       { "$type": "color", "$value": "{color.sky.400}" },
      "accent-primary-hover": { "$type": "color", "$value": "{color.sky.300}" },
      "accent-secondary":     { "$type": "color", "$value": "{color.sky.400}" },
      "accent-subtle-bg":     { "$type": "color", "$value": "{color.airforce.800}" },
      "accent-ember":         { "$type": "color", "$value": "{color.ember.300}" },
      "focus-ring":           { "$type": "color", "$value": "{color.sky.400}" },
      "status-success":   { "$type": "color", "$value": "{color.success.300}" },
      "status-warning":   { "$type": "color", "$value": "{color.warning.300}" },
      "status-error":     { "$type": "color", "$value": "{color.error.300}" },
      "status-info":      { "$type": "color", "$value": "{color.sky.300}" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" }
  },
  "radius": {
    "sm":   { "$type": "dimension", "$value": "6px" },
    "md":   { "$type": "dimension", "$value": "10px" },
    "lg":   { "$type": "dimension", "$value": "16px" },
    "xl":   { "$type": "dimension", "$value": "24px" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "font": {
    "family-latin": { "$type": "fontFamily", "$value": "Inter" },
    "family-cn":    { "$type": "fontFamily", "$value": "Noto Sans SC" },
    "family-serif": { "$type": "fontFamily", "$value": "Noto Serif SC" },
    "family-mono":  { "$type": "fontFamily", "$value": "JetBrains Mono" }
  }
}
